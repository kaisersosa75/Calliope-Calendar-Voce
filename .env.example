# --- App ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=                # stringa lunga e casuale
TIMEZONE=Europe/Rome

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/voicecal

# --- Cifratura token (32 byte in hex) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- OpenAI ---
OPENAI_API_KEY=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VOICE_FROM=

# --- SendGrid ---
SENDGRID_API_KEY=
EMAIL_FROM=
